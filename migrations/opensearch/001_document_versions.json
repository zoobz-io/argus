{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 1,
    "analysis": {
      "analyzer": {
        "content_analyzer": {
          "type": "standard",
          "max_token_length": 255
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "created_at": {
        "type": "date"
      },
      "updated_at": {
        "type": "date"
      },
      "version_id": {
        "type": "keyword"
      },
      "document_id": {
        "type": "keyword"
      },
      "tenant_id": {
        "type": "keyword"
      },
      "provider_id": {
        "type": "keyword"
      },
      "document_name": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "mime_type": {
        "type": "keyword"
      },
      "content": {
        "type": "text",
        "analyzer": "content_analyzer"
      },
      "summary": {
        "type": "text"
      },
      "language": {
        "type": "keyword"
      },
      "topics": {
        "type": "keyword"
      },
      "tags": {
        "type": "keyword"
      },
      "embedding": {
        "type": "knn_vector",
        "dimension": 1536,
        "method": {
          "name": "hnsw",
          "space_type": "cosinesimil",
          "engine": "lucene"
        }
      }
    }
  }
}
